# App-Konfiguration
appName = Meine App
appVersion = 1.0

# Entwickler-ID (dein Knuddels-Nickname)
developer = DEIN_NICK

# Server-Zuordnung
# knuddelsDE  = Live-Server
# knuddelsDEV = Dev-Server (zum Testen)
mayBeInstalledBy.0 = DEIN_NICK.knuddelsDEV

# iOS-Unterstützung (ohne Apple Developer ID öffnet sich die App nicht auf iOS)
# appleDeveloperId = DEINE_APPLE_ID
